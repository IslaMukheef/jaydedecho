# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Camera Settings
CAMERA_DEVICE_ID=0                        # 0 for default, or device number
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Maps & Routing (optional)
OPENROUTESERVICE_API_KEY=your_ors_key_here
DEFAULT_LOCATION_LAT=43.8509              # Default: Toronto, ON
DEFAULT_LOCATION_LNG=-79.0204

# Audio
AUDIO_OUTPUT_DEVICE=default               # System default

# Game Mode
GAME_MODE_ENABLED=true
DEFAULT_GAME=floor_is_lava

# Debug
DEBUG=false
LOG_LEVEL=INFO

